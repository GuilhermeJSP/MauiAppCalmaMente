<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppCalmaMente.Views.InicioPage">

    <ContentPage.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="20"/>
        </Style>
    </ContentPage.Resources>
    
    <VerticalStackLayout Padding="20" >

        <Image Source="emojifeliz.png"/>

        <Label Text="Olá, Como você se sente hoje?" HorizontalTextAlignment="Center"/>

        <Grid ColumnDefinitions="*,*" RowDefinitions="*,*">

            <Button Text="Diário" Clicked="Button_Clicked" Grid.Column="0" Grid.Row="0"/>

            <Button Text="Humor" Clicked="Button_Clicked_1" Grid.Column="0" Grid.Row="1"/> 

            <Button Text="Respire" Clicked="Button_Clicked_2" Grid.Column="1" Grid.Row="0"/>

            <Button Grid.Column="1" Grid.Row="1"/>

        </Grid>

    </VerticalStackLayout>

</ContentPage>