<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppCalmaMente.Views.RespirePage">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label Text="CalmaMente" FontSize="28" HorizontalOptions="Center"/>

        <Button Text="Respiração Guiada" Clicked="OnRespirar"/>

        <Button Text="🚨 Emergência"
                BackgroundColor="Red"
                TextColor="White"
                Clicked="OnEmergencia"/>

        <Grid HeightRequest="200" HorizontalOptions="Center">
            <BoxView x:Name="circulo"
                     WidthRequest="100"
                     HeightRequest="100"
                     CornerRadius="50"
                     BackgroundColor="LightBlue"/>
        </Grid>

    </VerticalStackLayout>

</ContentPage>